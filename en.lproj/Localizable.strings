"where_is_the_sun_at_a_given_time" = "Where is the sun at a given time?";
"where_the_sun_is_answer" = "The time and date at the top of the screen is always connected to what is being displayed on the screen. The sun is at the yellow circle at the given timeframe.\n\nChange the date by clicking the calendar or touch the screen to set that to the sun's position.\nYou can also drag the sun along the current dateline or jump to current time by clicking the circle button.";
"what_does_the_lines_represent" = "What do the lines represent?";
"yellow_line" = "Yellow line";
"yellow_line_answer" = "The yellow line shows the path of the sun on the defined date. You can also see where the sun will be every hour.";
"red_and_orange_line" = "Red and orange line";
"red_orange_answer" = "These lines show the path of the sun on the longest(orange) and shortest(red) day of the year. The sun will always be in between them.";
"gray_line" = "Gray line";
"gray_line_answer" = "The gray line is the horizon.";
"blue_line" = "Blue line";
"blue_line_answer" = "The blue line is an analemma for the current time of day. It can be toggled from settings and will always have an 8-shape. It shows where the sun will be at the current time of day for the whole year. It\'s the path the sun will take, if you take a picture every day at the same time for a year.";

