"where_is_the_sun_at_a_given_time" = "Hvor er solen på et givent tidspunkt?";
"where_the_sun_is_answer" = "Tidspunktet i toppen af skærmen er altid forbundet til, hvor solen vises. Solen er ved dens ikon på det givne tidspunkt.\n\nDu kan ændre datoen ved at klikke på kalender ikonet, eller tryk på skærmen for at finde ud af, hvornår solen er der.\nDu kan også trække solen langs den nuværende dagslinje eller gå tilbage til nuet, ved at trykke på cirkel-knappen.";
"what_does_the_lines_represent" = "Hvad viser de farvede linjer?";
"yellow_line" = "Gul linje";
"yellow_line_answer" = "Den gule linje viser solens bane på en givet dato. Du kan også se, hvor solen er ved hver time på dagen.";
"red_and_orange_line" = "Rød og orange linje";
"red_orange_answer" = "Disse linjer viser solens baner ved solhverv. Dvs. den længste(orange) og korteste(rød) dag på året. På ethvert andet tidspunkt vil solen altid befinde sig imellem dem.";
"gray_line" = "Grå linje";
"gray_line_answer" = "Den grå linje er horisonten.";
"blue_line" = "Blå linje";
"blue_line_answer" = "Den blå linje er et analemma for det viste klokketidspunkt. Man kan slå det til og fra i indstillingerne, og linjen vil altid linje et 8-tal. Den viser hvornår solen er ved det pågældende klokkeslæt, men for hele året. Det er den bane solen ville tage, hvis man tog et billede hver dag på samme tidspunkt i et helt år.";

"button_descriptions" = "Hvad knapperne gør";
